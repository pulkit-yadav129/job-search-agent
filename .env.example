# ── OpenAI ──────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here

# ── LangSmith Tracing ───────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=job-search-agent

# ── Job Search APIs ─────────────────────────────────
SERPAPI_KEY=your_serpapi_key_here
JSEARCH_RAPIDAPI_KEY=your_jsearch_rapidapi_key_here

# ── Naukri (via RapidAPI) ───────────────────────────
NAUKRI_RAPIDAPI_KEY=your_naukri_rapidapi_key_here

# ── LinkedIn (via RapidAPI) ─────────────────────────
LINKEDIN_RAPIDAPI_KEY=your_linkedin_rapidapi_key_here

# ── Email Alerts (Gmail SMTP) ───────────────────────
ALERT_EMAIL_SENDER=your_gmail@gmail.com
ALERT_EMAIL_PASSWORD=your_gmail_app_password
ALERT_EMAIL_RECIPIENT=recipient@example.com